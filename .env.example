APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-api-key
APPWRITE_DATABASE_ID=your-database-id
APPWRITE_JOBS_COLLECTION_ID=jobs
APPWRITE_LOGS_COLLECTION_ID=logs
APPWRITE_DATABASE_JOBS_TABLE=jobs
APPWRITE_DATABASE_LOGS_TABLE=logs
HEARTBEAT_INTERVAL_MS=10000
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=qwen/qwen3.6-plus:free
OPENROUTER_FALLBACK_MODELS=qwen/qwen3-32b:free,meta-llama/llama-3.3-70b-instruct:free
MAX_OPENROUTER_RETRIES=3
AVERAGE_VOICEOVER_WPS=2.7
